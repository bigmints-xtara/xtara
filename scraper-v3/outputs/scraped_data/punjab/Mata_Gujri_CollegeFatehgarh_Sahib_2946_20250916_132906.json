    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "Our teachers and all authorities of college to help students for in all cases",
          "name": "OM KAURA",
          "course_tag_name": "BA"
        },
        {
          "text": "Enough opportunities available to show your calibre.",
          "name": "Manminder singh",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "Teachers are very friendly and supportive.",
          "name": "Manminder singh",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "Numerous student and campus facilities are provided be the college like cafeteria,mess, sports ground, and many more.",
          "name": "simra",
          "course_tag_name": "BCA"
        },
        {
          "text": "This college pay much emphasis on both the education and sports",
          "name": "simra",
          "course_tag_name": "BCA"
        },
        {
          "text": "According to me the placement opportunities for bachelor students can be improved more via more industrial visit for students.",
          "name": "simra",
          "course_tag_name": "BCA"
        },
        {
          "text": "I like the that teacher are really punctual and knowledgeable here the student who are really serious for their studies should choose this college.",
          "name": "Jasleen Kaur",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "Here everyone gets entry with their I'd card so security is good as outsiders are not allowed",
          "name": "Jasleen Kaur",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "There Are Right About 5K Students And Lots Of Socialization Opportunities",
          "name": "Vishav Deep Singh",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "The Infrastructure Is Really Good There Are Lots Of Parks And Canteen's",
          "name": "Vishav Deep Singh",
          "course_tag_name": "B.Com {Hons.}"
        }
      ],
      "neg_sentences": [
        {
          "text": "Not enough books and study mat available in libraries",
          "name": "Anonymous",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "There was no facility of online classes in our college",
          "name": "OM KAURA",
          "course_tag_name": "BA"
        },
        {
          "text": "Online payment and other facilities can be improved.",
          "name": "Manminder singh",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "Students have to pay extra money for prospects while taking admission here",
          "name": "simra",
          "course_tag_name": "BCA"
        },
        {
          "text": "According to me more scholarship should be given to the students who are less fortunates but have good academic grades",
          "name": "simra",
          "course_tag_name": "BCA"
        },
        {
          "text": "Hostel timings are really early only till 5:00 in winters and 6:00 in summers",
          "name": "Jasleen Kaur",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "everyone knows that student also want some enjoyment along with study some events and all but they don't organise such things there are just small competitions like we have in schools but not like other colleges have.",
          "name": "Jasleen Kaur",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "Parking Facility Is Really Crowded And Uneven",
          "name": "Vishav Deep Singh",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "The Timings Are Really Inconvenient For Students Who live Far Away",
          "name": "Vishav Deep Singh",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "Transportation Facilities Need To Be Improved",
          "name": "Vishav Deep Singh",
          "course_tag_name": "B.Com {Hons.}"
        }
      ]
    }
  },
