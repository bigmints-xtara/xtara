    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "The course was structured really well, and its designed in a way that you have the option of pursuing other things as well or deeply pursuing your course",
          "name": "College Ninja",
          "course_tag_name": "BBA"
        },
        {
          "text": "The staff take regular feedbacks after every fractal about our professors and we get to rate them. They take this rating seriously.",
          "name": "College Ninja",
          "course_tag_name": "BBA"
        },
        {
          "text": "All the faculty are really experienced and knowledgeable.",
          "name": "RAHUL REDDY GADE",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Study faculty is very friendly in nature and very supportive",
          "name": "Harsha sri",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "The variety of courses and the experienced teachers",
          "name": "Nikshipta Reddy",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Good Faculty.All Faculty will be from IIT's Or NIT's .Main course professor are phd holders from IIT's",
          "name": "Yashwanth Reddy",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "The relevance and rigor of the course curriculum to your personal and professional development. Is tooo good it will be like focus on what we will be going to do in future",
          "name": "Yashwanth Reddy",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Library has many books relating to engineering, law, business administration. One of finest as compared to other private ones",
          "name": "Bharadwaj B",
          "course_tag_name": "BBALLB {Hons.}"
        },
        {
          "text": "The interaction new teachers and faculty are good",
          "name": "SAI SHREEKAR REDDI MALIGIREDDI",
          "course_tag_name": "B.Tech"
        }
      ],
      "neg_sentences": [
        {
          "text": "The extra curricular facilities are only open after 3pm.",
          "name": "RAHUL REDDY GADE",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Fees course fees is high very high not affordable for every one",
          "name": "Harsha sri",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "The difficulty of the exams and more weightage",
          "name": "Nikshipta Reddy",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "The campus has least amount of refreshments, like fests etc",
          "name": "Bharadwaj B",
          "course_tag_name": "BBALLB {Hons.}"
        },
        {
          "text": "Fests are not regularly organised. There are only two major fests and no more fests for the whole year",
          "name": "Sherwin",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "The limited no of Sports in the university",
          "name": "SAI SHREEKAR REDDI MALIGIREDDI",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Exams held a little too often, and grading policy is very bad.",
          "name": "Rithvik Kaliga",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "The academic fees is too high for this quality of studies.",
          "name": "Chaitanya Goteti",
          "course_tag_name": "B.Tech"
        }
      ]
    }
