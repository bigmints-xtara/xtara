    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "The college is full of co-curricular activities, it has several clubs and a lot of opportunities, discipline is the priority.",
          "name": "Lakshya Majhani",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The college staff was good. Their behavior with students was friendly and helping.",
          "name": "Arpit Jain",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The staff and the teachers are very supportive.",
          "name": "Umang jha",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Discipline maintenance in collage is very good .  All students and professors are well dressed and well supportive .",
          "name": "Aditya yadav",
          "course_tag_name": "B.Com"
        },
        {
          "text": "There is a huge library which is more then 100 years old",
          "name": "Nimisha Chandra",
          "course_tag_name": "BA"
        },
        {
          "text": "there are many certificate courses qhich you can join .",
          "name": "Nimisha Chandra",
          "course_tag_name": "BA"
        },
        {
          "text": "Auditorium was good and faculty member are like friends",
          "name": "Swasti Nayak",
          "course_tag_name": "BBA"
        },
        {
          "text": "Faculty,  fests , events , library, staff",
          "name": "Vaibhavi Jha",
          "course_tag_name": "BBA"
        }
      ],
      "neg_sentences": [
        {
          "text": "This collage didn't provide sufficient internships and placement to the students .",
          "name": "Aditya yadav",
          "course_tag_name": "B.Com"
        },
        {
          "text": "When there is a free lecture students are not allow to go home",
          "name": "Swasti Nayak",
          "course_tag_name": "BBA"
        },
        {
          "text": "The number of lectures are less for the one day.",
          "name": "Anshu kashiv",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The placements here are also not of good qualities or say the quantity of campus placements, there are also limited or very few clubs or cultural programs for students.",
          "name": "Review Ninja",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The curriculum here is very rigid so or it is very demanding without much practical exposure, the college has also very strict attendance policy which can feel very constraining for students who are also preparing for other post graduate examination.",
          "name": "Review Ninja",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Less practical classes only theory class is available.",
          "name": "Aman Chandwani",
          "course_tag_name": "BBA"
        },
        {
          "text": "There too much of discipline like we are in school",
          "name": "Suhani Bhawsar",
          "course_tag_name": "BBA"
        }
      ]
    },
    "affiliated_to": {
      "name": "BU Bhopal, Bhopal"
    }
