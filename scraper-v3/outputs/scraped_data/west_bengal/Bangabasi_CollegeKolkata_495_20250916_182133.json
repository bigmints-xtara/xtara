    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "Library is big and you can sit and do self study",
          "name": "Debangshu Das",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Our college have there own dedicated sports ground at maidan.",
          "name": "Debangshu Das",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Well maintained & totally clean environment",
          "name": "Zoheb Akhar",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The Fees structure which is very affordable for any middle class student.",
          "name": "Gourab Nandi",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Connectivity is very good due to its proximity near the Sealdah Rail Station.",
          "name": "Gourab Nandi",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Teachers were very helpful and would help you whenever they want.",
          "name": "Bisal Sharma",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "The college is very affordable and located near the Station",
          "name": "Bisal Sharma",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "The syllabus are easy to understand . Infrastructure of course is great.",
          "name": "sanchari",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Library is quite large and has a great number of books",
          "name": "RANAJOY PAUL",
          "course_tag_name": "B.Sc {Hons.}"
        },
        {
          "text": "The college hosts exciting fests 2-3 times a year.",
          "name": "Irfan Ahmed",
          "course_tag_name": "B.Sc {Hons.}"
        }
      ],
      "neg_sentences": [
        {
          "text": "Very short Timings of classes and it's routine list",
          "name": "Zoheb Akhar",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The campus is too much congested and the nearby roads are very dirty.",
          "name": "Gourab Nandi",
          "course_tag_name": "B.Com"
        },
        {
          "text": "For Payment of fees there were long queues",
          "name": "Bisal Sharma",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "There are no 6 months between two semester. You have to immediately start your study after one semester done.",
          "name": "sanchari",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "and for Submission of Projects you have to wait in Lines for hours.",
          "name": "Bisal Sharma",
          "course_tag_name": "B.Com {Hons.}"
        },
        {
          "text": "Laboratory are not maintained properly so it can be improved",
          "name": "RANAJOY PAUL",
          "course_tag_name": "B.Sc {Hons.}"
        },
        {
          "text": "Cultural fest is conducted but the hall room is not so large for all the students",
          "name": "RANAJOY PAUL",
          "course_tag_name": "B.Sc {Hons.}"
        },
        {
          "text": "Some areas need improvement, such as broken lights and fans.",
          "name": "Irfan Ahmed",
          "course_tag_name": "B.Sc {Hons.}"
        },
        {
          "text": "There's no big playground available for students to engage in physical activity",
          "name": "Mandip singh",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The admission process could have gone smoother in my case.",
          "name": "Saheli Saha",
          "course_tag_name": "BA {Hons.}"
        }
      ]
    },
