    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "You can also do distance learning here And here the percentage is very good even for distance learning",
          "name": "Rakhi kumari sah",
          "course_tag_name": "B.Sc (Ag.)"
        },
        {
          "text": "You will get many courses here and that too at a much lower cost than other places",
          "name": "Rakhi kumari sah",
          "course_tag_name": "B.Sc (Ag.)"
        },
        {
          "text": "Many cultural activities are organised here from time to time, like singing competitions, dancing competitions, farmers' fairs and also employment fairs, where all the children can participate.",
          "name": "Rakhi kumari sah",
          "course_tag_name": "B.Sc (Ag.)"
        },
        {
          "text": "The campus here is very beautiful and clean and a very good library is also provided here.",
          "name": "Rakhi kumari sah",
          "course_tag_name": "B.Sc (Ag.)"
        }
      ],
      "neg_sentences": [
        {
          "text": "Here you are taken on an educational tour only once a year for agriculture and also sometimes for other places the college selects the nearby area",
          "name": "Rakhi kumari sah",
          "course_tag_name": "B.Sc (Ag.)"
        },
        {
          "text": "No internship or placement is provided to the people coming here by the college for BSc Agriculture",
          "name": "Rakhi kumari sah",
          "course_tag_name": "B.Sc (Ag.)"
        },
        {
          "text": "There is a need to improve the food in the hostel mess, the food here is not as good quality wise as it should be",
          "name": "Rakhi kumari sah",
          "course_tag_name": "B.Sc (Ag.)"
        }
      ]
    },
    "affiliated_to": {
      "name": "RMLAU, Ayodhya"
    }
