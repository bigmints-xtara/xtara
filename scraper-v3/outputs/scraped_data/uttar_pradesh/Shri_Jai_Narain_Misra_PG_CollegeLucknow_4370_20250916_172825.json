    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "College campus is very big and all the facilities are available.",
          "name": "Tamanna Gupta",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Teachers are very supportive and friendly.",
          "name": "Tamanna Gupta",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Teaching style of each and every teacher is very nice.",
          "name": "Tamanna Gupta",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Safety of students especially girls in campus",
          "name": "Aayush tiwari",
          "course_tag_name": "BA"
        },
        {
          "text": "Easy and affordable fees with good scholarship",
          "name": "Aayush tiwari",
          "course_tag_name": "BA"
        },
        {
          "text": "Good and hygienic infrastructure with attequate some of croud management",
          "name": "Anonymous",
          "course_tag_name": "BBA"
        },
        {
          "text": "Library is very big and all books are available there",
          "name": "Nikhil Agarwal",
          "course_tag_name": "B.Com"
        },
        {
          "text": "It's near railway station and have 24 hour transportation facility",
          "name": "Review Rebel",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Canteen facility in affordable prices availability for all with tasty snacks",
          "name": "Mansi Sharma",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Ground was perfect for any kind of sports",
          "name": "Manas Srivastava",
          "course_tag_name": "B.Com"
        }
      ],
      "neg_sentences": [
        {
          "text": "Infrastructure could have been better and needs some improvement.",
          "name": "Tamanna Gupta",
          "course_tag_name": "B.Com"
        },
        {
          "text": "No AC even in classroom after paying nearly 25k as fees even ceiling fans are not maintained regularly",
          "name": "Anonymous",
          "course_tag_name": "BBA"
        },
        {
          "text": "No placement at all no internship program the placement cell is like a tooth less tiger",
          "name": "Anonymous",
          "course_tag_name": "BBA"
        },
        {
          "text": "The canteen is very far from commerce faculty needs more time to reach than time allotted for break",
          "name": "Anonymous",
          "course_tag_name": "BBA"
        },
        {
          "text": "Sometimes I dislike the teaching methods",
          "name": "Vertika Tripathi",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Because of it's near the station the traffic jam is the serious issue",
          "name": "Review Rebel",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Parking facility hastle as bikes scooty are in abundance",
          "name": "Mansi Sharma",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Time of classes with continuous schedule",
          "name": "Mansi Sharma",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Dress is compulsory but think it should not be after all it's college life",
          "name": "Varsha panjwani",
          "course_tag_name": "BA"
        },
        {
          "text": "Ground should have to clean in weekly basis",
          "name": "Manas Srivastava",
          "course_tag_name": "B.Com"
        }
      ]
    },
