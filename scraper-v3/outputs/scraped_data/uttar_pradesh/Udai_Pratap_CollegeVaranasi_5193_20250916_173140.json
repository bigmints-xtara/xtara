    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "So there way teaching was good like professors used to teach in both hindi and english",
          "name": "amisha tiwari",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The environment was good and Professors were attentive to every students there.",
          "name": "amisha tiwari",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The whole staff was good and always helpful and and the teachers were always ready to solve our prblem",
          "name": "amisha tiwari",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Central library is in the same place and having capacity of more than 100 students an library inchrge is nice person.",
          "name": "Rating Sage",
          "course_tag_name": "M.Sc"
        },
        {
          "text": "College should think about placement more",
          "name": "Piyush Pathak",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Students are too cool, and they don't have attitude",
          "name": "Shachi",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "College have different different type of facilties",
          "name": "Shachi",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Our classes facility good and provide smart classes",
          "name": "Ayush sonkar",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Large classes, Stressful exams, Poor dorm food, High tuition, and Overworked faculty and staff.",
          "name": "Arman sonkar",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Practicals are held regularly here,(daily 3hrs class) in case of Science stream.",
          "name": "Shubham Singh",
          "course_tag_name": "B.Sc"
        }
      ],
      "neg_sentences": [
        {
