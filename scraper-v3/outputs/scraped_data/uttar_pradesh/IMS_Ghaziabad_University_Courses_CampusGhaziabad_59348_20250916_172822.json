        },
        {
          "text": "No politics in college and hassle free classes.",
          "name": "Deepanshu chaudhary",
          "course_tag_name": "BBA"
        }
      ],
      "neg_sentences": [
        {
          "text": "The worst and most dislike think about the college is it has 75% attendance criteria necessary",
