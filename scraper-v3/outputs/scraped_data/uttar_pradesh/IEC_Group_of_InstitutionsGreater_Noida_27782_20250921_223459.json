          "course_tag_name": "B.Tech {Lateral}"
        },
        {
          "text": "College faculty is so good they support us in every aspects they provide us lab time to time and don't pressure us to take stress",
          "name": "Aditya singj",
          "course_tag_name": "B.Tech {Lateral}"
        }
      ],
