    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "Campus experience is good and we communicate with different districts of students and they all are toppers and gain good marks in 12th class.",
          "name": "Devraj Singh Chundawat",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Campus had various labs for different departments by which practicals had been done.",
          "name": "Chetan Goyal",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "In campus,a library for books and study .very well maintained and peaceful environment",
          "name": "Chetan Goyal",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Very good environment for study. The students who applied for bsc and bca can must visit our college",
          "name": "Chetan Goyal",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "There are big library in college campus, atleast 100000+ books are stored in library.",
          "name": "Bharat Kumawat",
          "course_tag_name": "BCA"
        },
        {
          "text": "Some teachers are very helpful like networking teacher.",
          "name": "Bharat Kumawat",
          "course_tag_name": "BCA"
        },
        {
          "text": "Campus environment is very good. College ground is awesome.",
          "name": "Bharat Kumawat",
          "course_tag_name": "BCA"
        }
      ],
      "neg_sentences": [
        {
          "text": "Lab condition are not very good. And the summary is - This college is best only for bsc students not for bca student.",
          "name": "Bharat Kumawat",
          "course_tag_name": "BCA"
        },
        {
          "text": "Atleast 100000+ books available in library but ,for bca student only 100-200 books are available and very few books are new otherwise all are old.",
          "name": "Bharat Kumawat",
          "course_tag_name": "BCA"
        },
        {
          "text": "There is little issue in results for which responsibility is Rajasthan University.",
          "name": "Narendra Singh",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Hostel facilities are not good in the college of rajasthan University",
          "name": "Lalit Bansal",
          "course_tag_name": "B.Sc {Hons.}"
        },
        {
          "text": "College student strength is less in comparison to other colleges",
          "name": "Lalit Bansal",
          "course_tag_name": "B.Sc {Hons.}"
        },
        {
          "text": "Maharaja college jaipur is only for boys so due to this communication skill not devloped and phobia to opposite gender intraction also developed.",
          "name": "Devraj Singh Chundawat",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Lack of sports ground and maintaince of ground and not more focus on sports activities.",
          "name": "Devraj Singh Chundawat",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "In Mahraja College jaipur students not come regular so teachers also not focus more on teaching and they also free mind.",
          "name": "Devraj Singh Chundawat",
          "course_tag_name": "B.Sc"
        }
      ]
