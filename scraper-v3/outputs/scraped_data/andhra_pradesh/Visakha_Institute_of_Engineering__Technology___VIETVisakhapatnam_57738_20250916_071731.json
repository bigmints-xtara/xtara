    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "We have to playground and indoor sports also available.",
          "name": "Gowdu Durga Mahesh",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "We have good teaching staff and there are friendly with students.",
          "name": "Gowdu Durga Mahesh",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Good environment ,and I like they way teach us",
          "name": "Killada shankar",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "The surroundings and nature of our college . Greenary is best in our college . Mountains and trees in college were so beautiful. It gives nostalgic feeling.",
          "name": "Kadavala Devi Sri",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Thing's I liked most in my college is our classrooms and labs which they are maintained hygiene and clean. So we're interested to do thing's in classes or labs. So basically we have a great lighting and fresh air in our college premises.",
          "name": "Modalavalasa Sai Kumar",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Peaceful environment and greenery, encouragement on cultural activities by college management is good, providing digital classes, guest lecturers.",
          "name": "Bhanusri",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "In our college, the administration is excellent and they conduct good sport activities and cultural activities",
          "name": "Mudadla naveen",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "The convience can be better than other colleges",
          "name": "Kaki sai prakash reddy",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Engaging Faculty: Supportive and knowledgeable professors.",
          "name": "divya",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Placement Support: Good industry connections and guidance.",
          "name": "divya",
          "course_tag_name": "B.Tech"
        }
      ],
      "neg_sentences": [
        {
          "text": "The Hostel facilities are not good at all.",
          "name": "Gowdu Durga Mahesh",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "In computer lab, some of the computer are not at proper condition.",
          "name": "Gowdu Durga Mahesh",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "We don't have proper public transport facilities to reach the college.",
          "name": "Gowdu Durga Mahesh",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Specific gate is not there , security also not good ,bus parking places ,college surrounding area not good",
          "name": "Killada shankar",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "They should intrested in others activities and they should not provide technical activities",
          "name": "Killada shankar",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Placements should be more package . They should conduct more internships . More workshops should be done .",
          "name": "Kadavala Devi Sri",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "Collecting fines for late coming and non uniform.",
          "name": "Bhanusri",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "There is no peaceful place to study for the hostelers",
          "name": "Mudadla naveen",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "The sports facilities is much poor in this college",
          "name": "Kaki sai prakash reddy",
          "course_tag_name": "B.Tech"
        },
        {
          "text": "The campus is small rather than comparison to other colleges",
          "name": "Kaki sai prakash reddy",
          "course_tag_name": "B.Tech"
        }
      ]
    },
