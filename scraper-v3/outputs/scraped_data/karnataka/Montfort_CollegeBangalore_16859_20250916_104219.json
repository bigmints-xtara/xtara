    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "The campus is green and vibrant in terms of environment",
          "name": "Tanya",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The canteen and hostel facilities are good, since both girls and boys hostel is the the college campus",
          "name": "Tanya",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The seats available are fewer and hence makes up for the lesser students = more attention",
          "name": "Tanya",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The faculty is trained with half of them having doctorate",
          "name": "Prarthana Suresh Kumar",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The place is small but beautiful, located in the heart of the city",
          "name": "Prarthana Suresh Kumar",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "One stop metro station, helps people coming from far places",
          "name": "Prarthana Suresh Kumar",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Infrastructure in general is amazing. A small campus but very very green. The lawn area is the spot to just sit and chat with friends.",
          "name": "Jerald emmanuel",
          "course_tag_name": "M.Sc"
        },
        {
          "text": "The faculty are really friendly and also we can share anything with them. The teaching also is really good",
          "name": "Jerald emmanuel",
          "course_tag_name": "M.Sc"
        }
      ],
      "neg_sentences": [
        {
          "text": "There are a lot of last minute notices in terms of cultural activities",
          "name": "Tanya",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The Staff members are not very permanent.",
          "name": "Tanya",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The canteen is small and the options are limited",
          "name": "Prarthana Suresh Kumar",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The PG and UG share the same lab facilities that sometimes inconveniences us both",
          "name": "Prarthana Suresh Kumar",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The parking space and sports involvement is comparatively less",
          "name": "Prarthana Suresh Kumar",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The college is affiliated with BNU therefore many times the dates of holidays or exams are known at the last moment.",
          "name": "Jerald emmanuel",
          "course_tag_name": "M.Sc"
        },
        {
          "text": "The canteen is limited and not much variety in the menu bit it works for me.",
          "name": "Jerald emmanuel",
          "course_tag_name": "M.Sc"
        }
      ]
    },
