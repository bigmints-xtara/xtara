    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "Good patient input attached to government hospital",
          "name": "Nithish",
          "course_tag_name": "MBBS"
        },
        {
          "text": "Good clinical exposure best professors and clinicians",
          "name": "Nithish",
          "course_tag_name": "MBBS"
        },
        {
          "text": "Good college best faculty good environment",
          "name": "Bharath",
          "course_tag_name": "MBBS"
        },
        {
          "text": "The faculty strength is very good and there are range of options.",
          "name": "DHEEMANTH R",
          "course_tag_name": "MBBS"
        },
        {
          "text": "Academics, sports opportunities, labs - 9/10",
          "name": "Hameem Raza Ali",
          "course_tag_name": "MBBS"
        },
        {
          "text": "clinical exposure - 8/10 (both private and govt hospitals linked to the college so patient load is very high)",
          "name": "Hameem Raza Ali",
          "course_tag_name": "MBBS"
        },
        {
          "text": "The teaching staff is on average very skilled in each department of the 1st year. Concepts can be easily grasped and understood. Emphasis on application skills is present.",
          "name": "Vrinda Sanal",
          "course_tag_name": "MBBS"
        },
        {
          "text": "Opportunities for research works in various fields are available and guided by our mentors for same",
          "name": "Nitika chhabra",
          "course_tag_name": "MBBS"
        },
        {
          "text": "Laboratories are highly furnished and functional.Classrooma are spacious and digital screens and big sitting area for students.",
          "name": "Nitika chhabra",
          "course_tag_name": "MBBS"
        },
        {
          "text": "Teachings are mainly in english so good for non karnataka students",
          "name": "Nitika chhabra",
          "course_tag_name": "MBBS"
        }
      ],
      "neg_sentences": [
        {
          "text": "Less cultural programmes very few extra curricular activities",
          "name": "Nithish",
          "course_tag_name": "MBBS"
        },
        {
          "text": "Interns who come in private seat usually get very less stipend or sometimes no stipend",
          "name": "Nithish",
          "course_tag_name": "MBBS"
        },
        {
          "text": "No places to hangout around Davangere not so supporting summer",
          "name": "Bharath",
          "course_tag_name": "MBBS"
        },
        {
          "text": "Very few extra curricular activities no college canteen",
          "name": "Bharath",
          "course_tag_name": "MBBS"
        },
        {
          "text": "The strength is quite high so individual attention is difficult.",
          "name": "DHEEMANTH R",
          "course_tag_name": "MBBS"
        },
        {
          "text": "General hostel for boys is outdated, though new construction in progress",
          "name": "Hameem Raza Ali",
          "course_tag_name": "MBBS"
        },
        {
          "text": "In extracurricular activities, college mainly appreciate sports over fests ,festival celebrations etc",
          "name": "Nitika chhabra",
          "course_tag_name": "MBBS"
        },
        {
          "text": "There is Language barrier for non Kannada students in postings and classrooms so they have to learn kannada as swiftly as possible",
          "name": "Nitika chhabra",
          "course_tag_name": "MBBS"
        },
        {
          "text": "There is no availability of internship for non karnataka students yet.",
          "name": "Nitika chhabra",
          "course_tag_name": "MBBS"
        },
        {
          "text": "There isn't a college sports ground of any sort",
          "name": "Medha",
          "course_tag_name": "MBBS"
        }
      ]
    },
    "affiliated_to": {
      "name": "RGUHS, Bangalore"
    }
  },
