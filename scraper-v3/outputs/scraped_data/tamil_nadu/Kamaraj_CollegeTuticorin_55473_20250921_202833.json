    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "Is that most pair was really good and the faculty members were well experienced and they provide more knowledge in skills for the students, there is a rule that girls in boys shouldn't talk to each other during class times",
          "name": "Sania ganges A",
          "course_tag_name": "BCA"
        },
        {
          "text": "The staffs encourage the students to persevere their skills and focus on their career too",
          "name": "Samuel Selva Ragland Manaza M",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "There are culturals and symposiums that are conducted by the students of the department",
          "name": "Samuel Selva Ragland Manaza M",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Atmosphere is good and also the management improving it.",
          "name": "Samuel Selva Ragland Manaza M",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "By asking the permission from the teacher of we can talk to boys or girls during class hours.",
          "name": "Sania ganges A",
          "course_tag_name": "BCA"
        }
      ],
      "neg_sentences": [
        {
          "text": "The thing that I dislike in this college is the fee structure is gradually increasing and some teachers of staff members see partiality among the students between the topper and the slow learners and they don't take care of the slow learners",
          "name": "Sania ganges A",
          "course_tag_name": "BCA"
        },
        {
          "text": "There are 10 girls and 30 boys in my class",
          "name": "Samuel Selva Ragland Manaza M",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "There is no confirmed placements but there are placements that are not even close to the computer science students",
          "name": "Samuel Selva Ragland Manaza M",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "No coordination and bad relationship with other department",
          "name": "Samuel Selva Ragland Manaza M",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The socialization with other department students is poor.",
          "name": "Samuel Selva Ragland Manaza M",
          "course_tag_name": "B.Sc"
        }
      ]
    },
