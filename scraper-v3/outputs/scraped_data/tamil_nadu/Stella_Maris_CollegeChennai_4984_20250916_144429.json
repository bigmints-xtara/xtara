    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "Faculties were friendly to every students and they will also recommend things which are good to us.",
          "name": "Jenifer",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Comfortable classrooms with more spacious",
          "name": "Monisha",
          "course_tag_name": "B.Com"
        },
        {
          "text": "There are 4 canteens and also stalls inside the college",
          "name": "SRINIDHI S",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The traditional buildings that gives you vintage vibes",
          "name": "Pradhanya",
          "course_tag_name": "B.Com"
        },
        {
          "text": "There are also alot of clubs and every club is run by students with a faculty incharge.",
          "name": "Rithika Rebecca Rajesh",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The syllabis is quite advance and  Easy.",
          "name": "farlath",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Our placement opportunities are very good",
          "name": "R Roshini",
          "course_tag_name": "BA"
        },
        {
          "text": "They give more importance to extra curricular activities like dances, sports, music , arts and crafts",
          "name": "Maithili",
          "course_tag_name": "M.Sc"
        },
        {
          "text": "College Environment and college cultural programs",
          "name": "Reona",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Cleanliness around the campus and outside the campus",
          "name": "Reona",
          "course_tag_name": "B.Com"
        }
      ],
      "neg_sentences": [
        {
          "text": "College timings for shift 2 students is worst",
          "name": "Reona",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Attendance percentage was too hard to maintain in need.",
          "name": "Jenifer",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Little high cost of canteen foods provided with low quantities",
          "name": "Pradhanya",
          "course_tag_name": "B.Com"
        },
        {
          "text": "College is pretty strict on dress code even though it is an all girls college",
          "name": "Rithika Rebecca Rajesh",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Stella was strict about students leaving earlier before the closing bell.",
          "name": "Shobana S",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Does not have street vendors outside college unlike MOP which had mushroom.",
          "name": "Shobana S",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The ventilation in the classroom is very bad",
          "name": "Lincy",
          "course_tag_name": "B.Com"
        },
        {
          "text": "They can provide with any special course for the students who seeks for any job immediately after they finish the graduation",
          "name": "Ezhilarasi K",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The canteens don't sell water bottles as our college frowns upon plastic waste",
          "name": "Angelina Pinto",
          "course_tag_name": "B.V.A"
        },
        {
          "text": "The areas for parking are limited which makes it difficult for the students",
          "name": "M BHUVANESWARI",
          "course_tag_name": "B.Sc"
        }
      ]
    },
