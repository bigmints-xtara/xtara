    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "And the placement here is sooo good and the training regarding placement is also professional.",
          "name": "Hemavarshini",
          "course_tag_name": "B.Com"
        },
        {
          "text": "We have many auditoriums and seminar halls which is very usefull",
          "name": "Sowjanya",
          "course_tag_name": "B.Com"
        },
        {
          "text": "You have various clubs like Rotaract,  NSS, NCC, Books club, Arts , etc.",
          "name": "Aswini",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Placement: My college provides many placement opportunities. Many reputed companies visit my college and recruit students",
          "name": "Priya",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Senior faculties are very good and knowledgeable.",
          "name": "Vineka",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Teaching is perfect  and good lab facilities.",
          "name": "ARSIDHA FARHANA",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Other than subjects they provide courses related to our career",
          "name": "Suguna M",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Some of the teachers teaching are good and it will be ok",
          "name": "Suguna M",
          "course_tag_name": "B.Com"
        },
        {
          "text": "They provide lectures from other college staff or professionals",
          "name": "Suguna M",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Placement they always offered us a high package placement",
          "name": "Karthika",
          "course_tag_name": "B.Com"
        }
      ],
      "neg_sentences": [
        {
          "text": "The semester exam fees are too high. For last semester they asked for 4000",
          "name": "Hemavarshini",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The correction method is not liked by many students in cart exams.",
          "name": "Hemavarshini",
          "course_tag_name": "B.Com"
        },
        {
          "text": "We are not allowed to play in the indoor stadium unless we have permission",
          "name": "Sowjanya",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Lots of homework and assignments will be given. They don't allow you to watch any event only participants can watch. Very strict college.",
          "name": "Aswini",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Online teaching: I want to improve online teaching in my college. It's very helpful to understand practically.",
          "name": "Priya",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Junior faculties are not so good and need some experience.",
          "name": "Vineka",
          "course_tag_name": "B.Com"
        },
        {
          "text": "No bus facility is available and it's very needed thing.",
          "name": "Vineka",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Parking is not good",
          "name": "Rithika",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The restrooms doesn't have proper access to water and no other issues",
          "name": "Tejal Jain",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Infrastructure inside the classroom need to be considered",
          "name": "Bharani Lakshmi S",
          "course_tag_name": "B.Com {Hons.}"
        }
      ]
    },
