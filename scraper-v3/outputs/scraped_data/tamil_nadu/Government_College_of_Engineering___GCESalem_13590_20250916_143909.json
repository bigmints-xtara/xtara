    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "Academics wise my college is great in my district",
          "name": "Monish",
          "course_tag_name": "BE"
        },
        {
          "text": "Then our facultys are friendly in teaching",
          "name": "Monish",
          "course_tag_name": "BE"
        },
        {
          "text": "Environment friendly for students to learn and enhance skills",
          "name": "Anishe k yepthomi",
          "course_tag_name": "BE"
        },
        {
          "text": "The lab equipments for most part although not perfect still gets the job done and overall importance for the practical experiments in each semester",
          "name": "Nishanth J",
          "course_tag_name": "BE"
        },
        {
          "text": "The student flexibility with allowing for almost any and every extra curricular activities or co curricular activities when approaching the faculty members",
          "name": "Nishanth J",
          "course_tag_name": "BE"
        },
        {
          "text": "The department i study in is rich with faculties, equipments and option for creativity",
          "name": "Abinu krishna S A",
          "course_tag_name": "BE"
        },
        {
          "text": "The infrastructure of the college is unlike anything in my city and i feel special to study here",
          "name": "Abinu krishna S A",
          "course_tag_name": "BE"
        },
        {
          "text": "The method of communication in teaching and learning is captivating",
          "name": "Abinu krishna S A",
          "course_tag_name": "BE"
        },
        {
          "text": "Clubs that engage people in every evening of Monday to Thursday which socially with other department students",
          "name": "SELVANANDHINI V",
          "course_tag_name": "BE"
        },
        {
          "text": "Open book visit after every correction of exam paper shows the valuation of semester papers transperancy and improved the pass percentage",
          "name": "SELVANANDHINI V",
          "course_tag_name": "BE"
        }
      ],
      "neg_sentences": [
        {
          "text": "Then Our instruments only limited worked for lab exams",
          "name": "Monish",
          "course_tag_name": "BE"
        },
        {
          "text": "The college is lacking a little bit behind in infrastructure",
          "name": "Anishe k yepthomi",
          "course_tag_name": "BE"
        },
        {
          "text": "The hostel facilities and food quality from what I've heard from my co classmates is not great, including the bathroom facilities",
          "name": "Nishanth J",
          "course_tag_name": "BE"
        },
        {
          "text": "The overall time given for completion of syllabus of a sem is very minimal and often results in crunch time for both the staff and students alike",
          "name": "Nishanth J",
          "course_tag_name": "BE"
        },
        {
          "text": "The classes are mostly theoretical and not practical",
          "name": "Abinu krishna S A",
          "course_tag_name": "BE"
        },
        {
          "text": "The lack of cultural events or cultural like events",
          "name": "Abinu krishna S A",
          "course_tag_name": "BE"
        },
        {
          "text": "The way to approach the higher authority is little complicated with rules and formalities",
          "name": "SELVANANDHINI V",
          "course_tag_name": "BE"
        },
        {
          "text": "The teaching is all done the their mother language which isn't beneficial",
          "name": "Anishe K Yepthomi",
          "course_tag_name": "BE"
        },
        {
          "text": "The are no advanced machines and materials",
          "name": "Vijayaprasanth P",
          "course_tag_name": "BE"
        },
        {
          "text": "Gym is not available",
          "name": "Sachin",
          "course_tag_name": "BE"
        }
      ]
    },
