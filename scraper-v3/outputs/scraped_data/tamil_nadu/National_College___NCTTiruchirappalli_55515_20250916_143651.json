    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "*Diverse Campus Life:* Vibrant cultural events, clubs and societies fostered strong social connections. 2. *Expert Faculty:* Professors' industry experience and research expertise enhanced learning. 3. *Robust Infrastructure:* Modern classrooms, lab",
          "name": "Sriakshay N",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The teachers are very friendly and supportive.",
          "name": "Reshma",
          "course_tag_name": "BBA"
        },
        {
          "text": "More than a theory classes they are offering more practical classes and enhancing more soft skills.",
          "name": "Reshma",
          "course_tag_name": "BBA"
        },
        {
          "text": "Sending every student to the other college confrence & competitions.",
          "name": "Reshma",
          "course_tag_name": "BBA"
        },
        {
          "text": "I liked there are many extracurricular activity and many clubs also is my favourite",
          "name": "G HARISH",
          "course_tag_name": "BCA"
        },
        {
          "text": "There are many well trained professor and best teaching",
          "name": "G HARISH",
          "course_tag_name": "BCA"
        },
        {
          "text": "In our college professor  are very friendly to our college students so we will freely connected with  professors",
          "name": "G HARISH",
          "course_tag_name": "BCA"
        }
      ],
      "neg_sentences": [
        {
          "text": "Classrooms are too far from the canteen and play ground",
          "name": "Purusothaman c",
          "course_tag_name": "M.Sc"
        },
        {
          "text": "It's shift was timings. Mostly aided students are morning shift and unaided students are afternoon shift.",
          "name": "Elakiya Selvi",
          "course_tag_name": "M.Sc"
        },
        {
          "text": "Then science students weakly once for lab to work monitor please increase weakly twice or thrice",
          "name": "G HARISH",
          "course_tag_name": "BCA"
        },
        {
          "text": "We pay it for college studies but the campus ask  money  to buy a guide in all subject this thing I hated",
          "name": "G HARISH",
          "course_tag_name": "BCA"
        },
        {
          "text": "There are interval time is so down  so please increase interval break time",
          "name": "G HARISH",
          "course_tag_name": "BCA"
        },
        {
          "text": "The infrastructure is poor and very small",
          "name": "Reshma",
          "course_tag_name": "BBA"
        },
        {
          "text": "Limited Financial Aid:* Scholarship opportunities were scarce for non-government-funded programs. 2. *Bureaucratic Administrative Processes:* Slow redressal of grievances and inefficient paperwork.",
          "name": "Sriakshay N",
          "course_tag_name": "B.Sc"
        }
      ]
