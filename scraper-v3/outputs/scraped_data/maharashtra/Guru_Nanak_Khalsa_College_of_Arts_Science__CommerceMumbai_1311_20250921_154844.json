    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "Teachers are always ready to address out doubts no matter how many time we asked",
          "name": "Pratik Dubey",
          "course_tag_name": "B.Com"
        },
        {
          "text": "I liked how sports was given equal importance as studies",
          "name": "Pratik Dubey",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The Nazarana Fest , this is the one and only fest we are waiting for whole year , its is very Amezing.",
          "name": "Aditya Gurav",
          "course_tag_name": "B.M.M"
        },
        {
          "text": "The play ground is too big to play and the auditorium also",
          "name": "College Ninja",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Management is good, appreciable but the department needed improvement",
          "name": "Piyali Manna",
          "course_tag_name": "BMS"
        },
        {
          "text": "Canteen has both veg and non veg options",
          "name": "Rishaa Pimenta",
          "course_tag_name": "M.Sc"
        },
        {
          "text": "The college has a huge library with alot of books to read.",
          "name": "Anonymous",
          "course_tag_name": "B.M.M"
        },
        {
          "text": "College Safety  is Very Amezing , Their was  one accident happened in our collage in my neighbors classroom , The AC got Fire and the fire sparred very fast , the collage staff very fast takes action and control  fire , No one gets injured .",
          "name": "Aditya Gurav",
          "course_tag_name": "B.M.M"
        }
      ],
      "neg_sentences": [
        {
          "text": "We had to wait in line for hours to make the fee payment",
          "name": "Pratik Dubey",
          "course_tag_name": "B.Com"
        },
        {
          "text": "College doesn't have its own parking to park the vehicle",
          "name": "Review guru",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The college does not have any lifts, the stairs are too long.",
          "name": "Anonymous",
          "course_tag_name": "B.M.M"
        },
        {
          "text": "There was no drive for placement, no support provided for career development",
          "name": "Piyali Manna",
          "course_tag_name": "BMS"
        },
        {
          "text": "Lack in interaction with mentor,  learning facilities are less",
          "name": "Piyali Manna",
          "course_tag_name": "BMS"
        },
        {
          "text": "Infrastructure need to be developed, need to do changes in amenities like benches",
          "name": "Piyali Manna",
          "course_tag_name": "BMS"
        },
        {
          "text": "Department FEST of Bmm(Bammc) , it was very bad and we dose not like it , it was very low budget fest, Fest Name is Elixir.",
          "name": "Aditya Gurav",
          "course_tag_name": "B.M.M"
        }
      ]
    },
