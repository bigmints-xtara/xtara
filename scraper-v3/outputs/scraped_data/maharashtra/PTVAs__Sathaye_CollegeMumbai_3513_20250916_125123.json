    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "I like the fact that they give plenty of time to play our favourite sports",
          "name": "rushabh santosh desai",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The other thing i like that there are many festivals, events organised in our college.",
          "name": "rushabh santosh desai",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The teaching skills of all lectures are also nice",
          "name": "rushabh santosh desai",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Faculties are easy to approach and coordinate well",
          "name": "Arya Salvi",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The garden and the Gymkhana also nice where we can play",
          "name": "Vikram Mahade",
          "course_tag_name": "BAF"
        },
        {
          "text": "Auditorium is full ac and spacious seating area",
          "name": "Paras Kalke",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Library has a lot of collection of books such as schelor lock Homes we can even sit in the library to study separate and group desks are also available library closes on 5 pm",
          "name": "Paras Kalke",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Attendance is not compulsory. Teachers do not scold.",
          "name": "College Ninja",
          "course_tag_name": "B.Com"
        },
        {
          "text": "College canteen which serves fresh and safe food.",
          "name": "Tanmay Lad",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Laboratories which are well equipped for experiments.",
          "name": "Tanmay Lad",
          "course_tag_name": "B.Sc"
        }
      ],
      "neg_sentences": [
        {
          "text": "The recess time is too short of our college",
          "name": "rushabh santosh desai",
          "course_tag_name": "B.Com"
        },
        {
          "text": "And the lecture are also too long in iur college",
          "name": "rushabh santosh desai",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Benches are not that comfortable they are two short for two people to fit in",
          "name": "Arya Salvi",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The department is lazy not taking lecture regularly",
          "name": "Vikram Mahade",
          "course_tag_name": "BAF"
        },
        {
          "text": "The canteen is to small and always occupied by senior",
          "name": "Vikram Mahade",
          "course_tag_name": "BAF"
        },
        {
          "text": "The examination scenario is bad. Timetable is not proper.",
          "name": "College Ninja",
          "course_tag_name": "B.Com"
        },
        {
          "text": "College auditorium is quite small for the size of campus.",
          "name": "Tanmay Lad",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Washrooms are quite old and are not disability friendly.",
          "name": "Tanmay Lad",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Lack of elevators for students who are unable to climb stairs.",
          "name": "Tanmay Lad",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The rooms are always humid and hot some fans even dont work, Some college staff is rude. Canteen food is not that good.",
          "name": "Aditya Gaonkar",
          "course_tag_name": "B.Com"
        }
      ]
    },
