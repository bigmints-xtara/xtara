    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "College provides bus service from college to the Railway station and vice versa.",
          "name": "Nirav Shelar",
          "course_tag_name": "BE"
        },
        {
          "text": "There is a lot to do other than just your course , you can participate in sports programs which are organised by college itself",
          "name": "Shriprasad Rakesh satve",
          "course_tag_name": "BE"
        },
        {
          "text": "Infrastructure: The college boasted modern facilities, well-equipped laboratories, and a resourceful library, enhancing the overall educational environment.",
          "name": "Chetana Bhoir",
          "course_tag_name": "BE"
        }
      ],
      "neg_sentences": [
        {
          "text": "Not enough campus placements for the final year and not any apprenticeship for freshers",
          "name": "Anonymous",
          "course_tag_name": "BE"
        },
        {
          "text": "Communication Gap: At times, there seemed to be a communication gap between students, faculty, and the administration, leading to misunderstandings or delays in addressing issues.",
          "name": "Chetana Bhoir",
          "course_tag_name": "BE"
        },
        {
          "text": "There are only 2 lifts and 5 floors which makes it hard for students to get to their next class on time",
          "name": "Shriprasad Rakesh satve",
          "course_tag_name": "BE"
        },
        {
          "text": "Only two lifts are provided, among which one only goes till the third floor and gets stuck if there is a power cutoff.",
          "name": "Nirav Shelar",
          "course_tag_name": "BE"
        },
        {
          "text": "College buiding is well constructed and designed till the 2nd floor, remaining 3floors look very old and unclean",
          "name": "Nirav Shelar",
          "course_tag_name": "BE"
        },
        {
          "text": "Washrooms are not clean on the third and fourth floor",
          "name": "Nirav Shelar",
          "course_tag_name": "BE"
        }
      ]
    },
