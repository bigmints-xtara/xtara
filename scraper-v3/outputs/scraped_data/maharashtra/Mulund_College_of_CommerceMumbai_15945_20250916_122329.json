    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "The faculty of college is very polite and helpful; teaching and non-teaching faculty both",
          "name": "Review guru",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "I liked the events held here. Spectrum is the name of the event held in december. Here the different days are held like traditional day, saree day,etc. On last day dj night was happened it was too much fun. But it contains.",
          "name": "Review guru",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Teachers, Canteen, Gymkhana, Fest, Politie STAFF",
          "name": "Tanay Aphale",
          "course_tag_name": "B.Com"
        },
        {
          "text": "No ragging is allowed and it creates a sense of safety within or outside the college premises.",
          "name": "Sanskruti Subodh Tamboli",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Quality of teaching is the major attraction of my college as they have a very good quality education.",
          "name": "Sakshi gaichor",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Teachers are very well qualified and are willing to help the students.",
          "name": "Sakshi gaichor",
          "course_tag_name": "B.Com"
        },
        {
          "text": "College has 2 libraries with wide range of books one is open access library and one is normal library",
          "name": "Neemuchwala Hussain Hatim",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Students interact with each other, seniors help juniors in assignment and other projects",
          "name": "Neemuchwala Hussain Hatim",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The thing which I loved it if students lost their belongings the cleaning faculty will be keeping safely and makes record that and handover to the responsible students",
          "name": "Disha Suvarna",
          "course_tag_name": "B.Com"
        },
        {
          "text": "I like the teaching method of a few of professors",
          "name": "Samruddhi S Valvi",
          "course_tag_name": "BMS"
        }
      ],
      "neg_sentences": [
        {
          "text": "teaching style, didnt coperate with the students who were doing CA Articleship",
