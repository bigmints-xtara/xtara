    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "class room ,library and practical lab is okk",
          "name": "Dipali murkute",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "our collage camp is also ok,placement and intership cells are avilable",
          "name": "Dipali murkute",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "teachers and teaching is best ,screen is available",
          "name": "Dipali murkute",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "I like how the atmosphere here is positive and joyful but also having a good reminder of what we are doing i.e. studying.",
          "name": "Ankur Vijay Gangawane",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The faculty is very good and skilled in their own respective fields and hold a good grasp on it.",
          "name": "Ankur Vijay Gangawane",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The course, especially Physics from where I am, is advanced in many aspects, we also do technical analysis and research on various things.",
          "name": "Ankur Vijay Gangawane",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Regular scheduled field visits for hands on learning experience.",
          "name": "Yash Ghardale",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Faculty are good they provide every material for exams. Assignment",
          "name": "Rohit Rampravesh Mandal",
          "course_tag_name": "B.Com"
        },
        {
          "text": "All classrooms have their own e-screens for digital learning",
          "name": "Aditya Patil",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Very Excellent and Intellgeint faculty and explains every concept precisely and througly",
          "name": "Soham Nitin Hulawale",
          "course_tag_name": "B.Com"
        }
      ],
      "neg_sentences": [
        {
          "text": "ground is not available,for playing diifrent play",
          "name": "Dipali murkute",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Also, the infrastructure is kind of average as they need to be updated well, but also in cooperative with the students and professors.",
          "name": "Ankur Vijay Gangawane",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Language/communication barrier between teaching staff and students.",
          "name": "Yash Ghardale",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Restrooms are very poorly maintained and water coolers are somewhat unhygienic.",
          "name": "Yash Ghardale",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Apart from the library, there's very little space on the campus to relax.",
          "name": "Yash Ghardale",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "The principal is bad very much hot game permission to do anything",
          "name": "Kunal Bharat Petkar",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Parking area which is to small so you have to park your vehicle in roadside area",
          "name": "Rohit Rampravesh Mandal",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Don't provide hostel facility and the Canteen is not maintained so students are forced to eat out of the premises or bring their own tiffin",
          "name": "Shaunak Thigale",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Does not have proper hall for organising events.",
          "name": "Vinit Lavleshkumar Shriwas",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Quality of education is not as much good as it should be",
          "name": "Zala Yuvraj Sinh",
          "course_tag_name": "B.Sc"
        }
      ]
    },
