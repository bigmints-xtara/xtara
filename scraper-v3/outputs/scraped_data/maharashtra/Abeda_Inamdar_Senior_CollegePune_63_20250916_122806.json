    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "The College Library is too good and I liked that also i spent sometimes frequently in library for reading books and studied",
          "name": "Khalil shakil sayyad",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The College sports ground is also my likeable place and I played cricket over there.",
          "name": "Khalil shakil sayyad",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The College's overall environment is too Fresh and energetic because of the trees and greenery in the college area",
          "name": "Khalil shakil sayyad",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Teachers are friendly and helpful, teaching is also good and study material is provided on time",
          "name": "Review Rebel",
          "course_tag_name": "B.Com"
        },
        {
          "text": "There's often events and not boring everyday",
          "name": "Review Rebel",
          "course_tag_name": "B.Com"
        },
        {
          "text": "There was huge availability of tecahers whene ever we needed for any kind of doubts and some or the other thing",
          "name": "Sanjna Suresh Shinde",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Good sports facilities are there if one is interested in sports, various kinds of competitions, fests.",
          "name": "Mohammad asif",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "AISC provides a good quality for both study and social life.",
          "name": "Faraz",
          "course_tag_name": "BBA"
        },
        {
          "text": "Teaching staff is very friendly and always ready to help",
          "name": "Uwais Ansari",
          "course_tag_name": "BBA"
        },
        {
          "text": "There are 3 canteens in the college with seeting accommodation",
          "name": "Shamaila Sajan",
          "course_tag_name": "BBA"
        }
      ],
      "neg_sentences": [
        {
          "text": "The College Canteen is not well and it's a bit of expensive",
          "name": "Khalil shakil sayyad",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The College hostel is also too old and amenities for day-to-day life are not there",
          "name": "Khalil shakil sayyad",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The College classroom is not up to the mark like paint and walls",
          "name": "Khalil shakil sayyad",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The process for anything like submitting applications in the office is time consuming",
          "name": "Review Rebel",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The college has very bad crowd, the slang and stupid things happening in college  is unhealthy",
          "name": "Sanjna Suresh Shinde",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "A little disturbance from outsiders as it's an open college",
          "name": "Faraz",
          "course_tag_name": "BBA"
        },
        {
          "text": "Rare places do not have wifi connections",
          "name": "Faraz",
          "course_tag_name": "BBA"
        },
        {
          "text": "Non teaching staff is very rude to student",
          "name": "Uwais Ansari",
          "course_tag_name": "BBA"
        },
        {
          "text": "No internship as of such provided by department.",
          "name": "Swaleha Mewegar",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "No placement cells, students don't get a chance for on-campus recruitment",
          "name": "Swaleha Mewegar",
          "course_tag_name": "B.Sc"
        }
      ]
    },
    "affiliated_to": {
      "name": "SPPU, Pune"
    }
  },
