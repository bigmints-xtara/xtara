    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "There are once a month some events in the college",
          "name": "College Ninja",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Gymkhana & library is the best part of the college",
          "name": "College Ninja",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Friendly principal and facilities good to interact with",
          "name": "College Ninja",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The Event Auto expo  that was organized. It was the best event",
          "name": "College Ninja",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The merit list for admission is low so that students with lower grade can also apply for the course they are looking for.",
          "name": "Janavi Kharat",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Their are some faculty which are good and they do put efforts for students to learn.",
          "name": "Janavi Kharat",
          "course_tag_name": "B.Com"
        },
        {
          "text": "They complete the syllabus in time and take revision which makes it strong",
          "name": "Saloni More",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Self study is the important point in distance learning only the students who can self study should apply for IDOl.",
          "name": "Siddhanth",
          "course_tag_name": "M.Com"
        },
        {
          "text": "The university is easily accessible from all over Mumbai.",
          "name": "Anonymous",
          "course_tag_name": "M.A"
        }
      ],
      "neg_sentences": [
        {
