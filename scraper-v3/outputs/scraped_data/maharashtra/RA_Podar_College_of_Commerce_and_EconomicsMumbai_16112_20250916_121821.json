    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "The faculty is good and cooperative they help and contact whenever required",
          "name": "Sumeet Anjarlekar",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The college is not very strict and offers various interactive programs",
          "name": "Sumeet Anjarlekar",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Transparency is offered by college regarding your marking system",
          "name": "Sumeet Anjarlekar",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The overall curriculum designed to ease the Acturial pursuing students is helpful and enjoying.",
          "name": "NUPOOR SHETYE",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The no minimum addendance of the college is the thing I liked the most.",
          "name": "Aditya Borate",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Events and teachers are helpful specially junior college teachers they help you understand everything in detail and give you personalised help sport team is also very good they welcome everyone to participate",
          "name": "Shubham tumma",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Infrastructure of the college is good it has traditional unique vibe of 1900s environment is pretty good in early morning with cold air and green garden in front of college which is kept well maintained",
          "name": "Shubham tumma",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Recently college have introduced new courses with can help student to take specific subject and help them to be productive in them and help their understanding of the subject more deeply which can benefit",
          "name": "Shubham tumma",
          "course_tag_name": "B.Com"
        }
      ],
      "neg_sentences": [
        {
          "text": "The college campus is not very Sapcious.",
          "name": "Anonymous",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The campus is a bit small as the students are around 600 to 800 every year",
          "name": "Sumeet Anjarlekar",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Network issues so problem contacting parents",
          "name": "Sumeet Anjarlekar",
          "course_tag_name": "B.Com"
        },
        {
          "text": "There is no canteen in the college so we have to go out",
          "name": "Sumeet Anjarlekar",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The syllabus can be managed effectively and efficiently.",
          "name": "NUPOOR SHETYE",
          "course_tag_name": "B.Com"
        },
        {
          "text": "More practicality of the course can be targeted.",
          "name": "NUPOOR SHETYE",
          "course_tag_name": "B.Com"
        },
        {
          "text": "I dislike the credit points system of the college where we have to collect a total of 12 credit points over a period of 3 years",
          "name": "Aditya Borate",
          "course_tag_name": "B.Com"
        }
      ]
    },
