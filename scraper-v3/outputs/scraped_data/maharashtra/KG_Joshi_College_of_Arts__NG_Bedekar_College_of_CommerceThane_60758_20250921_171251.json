    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "The college was very big and huge the infrastructure is also good",
          "name": "Vedika Sawant",
          "course_tag_name": "B.Com"
        },
        {
          "text": "the girl ratio was more than boys and the environment among the students were very ambicious to their goals",
          "name": "rushikesh sangale",
          "course_tag_name": "B.M.M"
        },
        {
          "text": "The teacher student relationship was good. They were quite understanding and helpful to provide each and every notes to us prior exams.",
          "name": "Yash Sanjiv Margaj",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The sports arena is as well quite good for students to play in.",
          "name": "Yash Sanjiv Margaj",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Library canteen nd Gymkhana is also well maintained.",
          "name": "Yash Sanjiv Margaj",
          "course_tag_name": "B.Com"
        },
        {
          "text": "There was no discrimination against any anyone there were more females than males and the environment still felt comfortable",
          "name": "Rishabh Shenoy",
          "course_tag_name": "BA"
        },
        {
          "text": "The faculty was were understanding and a bunch of real professionals",
          "name": "Rishabh Shenoy",
          "course_tag_name": "BA"
        },
        {
          "text": "There are many extracurricular activities like DLLE, NSS, NCC, CULTURAL COMMITTEE PROGRAMS , etc.",
          "name": "Tanya Baug",
          "course_tag_name": "BMS"
        },
        {
          "text": "Cultural events and fest are conducted in the college",
          "name": "Anonymous",
          "course_tag_name": "BMS"
        },
        {
          "text": "Opportunities like Youth is their. industrial visit happens, Other Real life Opportunities are available",
          "name": "Harshada",
          "course_tag_name": "B.M.M"
        }
      ],
      "neg_sentences": [
        {
          "text": "the faculty was very poor and  very irresponsible the college office counter are always closed poor service",
          "name": "rushikesh sangale",
          "course_tag_name": "B.M.M"
        },
        {
          "text": "the college infrastructure is very old and poor their was  not proper bench and the blackboard too very bad",
          "name": "rushikesh sangale",
          "course_tag_name": "B.M.M"
        },
        {
          "text": "Notices are not given on time. Prior notices for any lecture aren't given.",
          "name": "Yash Sanjiv Margaj",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Technology is lacked during online exams. Faces a lot of problem giving the exams.",
          "name": "Yash Sanjiv Margaj",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The assignments are mostly hand written work which needs lots of time and it is copying half of the textbook",
          "name": "Tanya Baug",
          "course_tag_name": "BMS"
        },
        {
          "text": "The gymkhana is one of the useless thing in the college , the timings are off and girls misses their opportunities to play most of the time.",
          "name": "Tanya Baug",
          "course_tag_name": "BMS"
        },
        {
          "text": "Computer lab, few computers are not working.",
          "name": "Aarya Chandorkar",
          "course_tag_name": "BMS"
        },
        {
          "text": "The education might have been better than the current level",
          "name": "Anand Bodekar",
          "course_tag_name": "BMS"
        },
        {
          "text": "No extra or special security only in the enterence",
          "name": "Vaishnav jayawant patil",
          "course_tag_name": "BA"
        }
      ]
    },
