    "like_dislike_summary": {
      "pos_sentences": [
        {
          "text": "The college was near by my residency and travelling was quite easy",
          "name": "Arsh uppal",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The college faculty was well experienced and the college got a nice infrastructure as well",
          "name": "Arsh uppal",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Great placements and internship opportunities as well the fests are really nice",
          "name": "Azma pagarkar",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The fest conducted in this college are very nice",
          "name": "KRINAL PAWAR",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Classrooms are bigger in size and benches are comfortable",
          "name": "KRINAL PAWAR",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Lab is well equipped and the location of this college is very convenient to travel",
          "name": "Rating Sage",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "With whole heart i would appreciate the cleanliness of my college, all the floors, the windows and the washrooms are extremely clean.",
          "name": "Krisha  Boricha",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Teaching terms are different and nice from other colleges which I liked the most",
          "name": "College Ninja",
          "course_tag_name": "BA"
        },
        {
          "text": "There are many improvement in me regarding social life as ive become a extrovert due to the association work in pr team which helped me to get along with anyone without any fear",
          "name": "College Ninja",
          "course_tag_name": "BA"
        },
        {
          "text": "Staff members aree very cooperative and cleanliness is the top priority of the college as I've seen",
          "name": "College Ninja",
          "course_tag_name": "BA"
        }
      ],
      "neg_sentences": [
        {
          "text": "Campus was small the class room should be improved especially the benches",
          "name": "Arsh uppal",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The library was always crowded and there’s always lack of concentration",
          "name": "Arsh uppal",
          "course_tag_name": "B.Com"
        },
        {
          "text": "The college should organize activities for students to engage with each other which was not seen in my tenure",
          "name": "Arsh uppal",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Parking issues sometime but its fine as per now",
          "name": "Azma pagarkar",
          "course_tag_name": "B.Com"
        },
        {
          "text": "There are so many fests held in this college",
          "name": "KRINAL PAWAR",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Washroom services are bad and the washrooms are dirty",
          "name": "KRINAL PAWAR",
          "course_tag_name": "B.Com"
        },
        {
          "text": "Workload and academic pressure is too much on students",
          "name": "Rating Sage",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Very limited extra curricular activities",
          "name": "Rating Sage",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "There is no lift for the students, everyday we have to climb 4 floors to attend the lectures.",
          "name": "Krisha  Boricha",
          "course_tag_name": "B.Sc"
        },
        {
          "text": "Canteen needs to get upgrade as soon as possible",
          "name": "shantanu tongay",
          "course_tag_name": "BA"
        }
      ]
    },
