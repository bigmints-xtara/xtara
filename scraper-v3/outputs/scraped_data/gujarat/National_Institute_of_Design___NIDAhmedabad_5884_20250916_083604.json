      "pos_sentences": [
        {
          "text": "The other students and how everyone is different from eachother.",
          "name": "Divyansh roat",
          "course_tag_name": "B.Des"
        },
        {
          "text": "The culture of nid is very rich and have a good alumni system",
          "name": "Divyansh roat",
          "course_tag_name": "B.Des"
        },
        {
          "text": "Everyone is very helpful and facilities is also very good and supportive",
          "name": "Divyansh roat",
          "course_tag_name": "B.Des"
        },
        {
          "text": "This is a really open and inclusive place irrespective of your gender , sexuality, caste etc.",
          "name": "Anonymous",
          "course_tag_name": "B.Des"
        },
        {
          "text": "Considering the fact that most of the courses here have visiting faculty it makes you open to new people and let’s you know more perspectives and help you think differently",
          "name": "Anonymous",
          "course_tag_name": "B.Des"
        }
      ],
      "neg_sentences": [
        {
          "text": "I guess they should change the curriculum since they have been following the same curriculum since the beginning and ig it’s high time that it gets updated",
          "name": "Anonymous",
          "course_tag_name": "B.Des"
        },
        {
          "text": "The infrastructure is really old which dates back to 1961 and over the time it has just been renewed and not completely furnished or reconstructed",
